{{ 'header.css' | asset_url | stylesheet_tag }}
{{ 'nav.css' | asset_url | stylesheet_tag }}

{% comment %} <header is="header" role="banner" class="christmas"> {% endcomment %}
<header is="header" role="banner">
  <a href="{{ routes.root_url }}" aria-label="Playpress">
    <img 
      src="{{ 'logo-no-r.svg' | asset_url }}"
      alt="Playpress logo"
      loading="lazy"
      width="600"
      height="400"
    />
  </a>
  <nav is="menu" aria-label="Main">
    <ul>
      <li>
        <a href="/pages/shop">
          Shop
        </a>
        <div class="dropdown">
          <ul>
            {% for link in linklists.dropdown-merchandising.links %}
              <li>
                <a is="collection-link" href="{{ link.url }}">
                  <p>{{ link.title }}</p>
                </a>
              </li>
            {% endfor %}
            <div class="divider"></div>
            {% for link in linklists.collections.links %}
              <li>
                <a is="collection-link" href="{{ link.url }}">
                  <p>{{ link.title }}</p>
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      </li>
      <li>
        <a href="/pages/studio">
          Studio
        </a>
      </li>
      <li>
        <a href="/pages/stock-us">
          Stock us
        </a>
      </li>
      <li>
        <a href="/pages/about">
          About
        </a>
        <div class="dropdown">
          <ul>            
            {% for link in linklists.about-menu.links %}
              <li>
                <a is="collection-link" href="{{ link.url }}">
                  <p>{{ link.title }}</p>
                </a>
              </li>
            {% endfor %}
            <div class="divider"></div>
            <li>
              <a is="collection-link" href="/pages/contact">
                <p>Contact us</p>
              </a>
            </li>
          </ul>
        </div>
      </li>
      {% comment %} {% for link in linklists.main-menu.links %}
        {% unless link.title == "Shop" %}
          <li {% if link.active %} class="on"{% endif %}>
            <a href="{{ link.url }}"
              {% if link.current %} aria-current="page"{% endif %}
            >{{ link.title }}
            </a>
          </li>
        {% endunless %}
      {% endfor %} {% endcomment %}
    </ul>
  </nav>
  <div class="header-actions">
    {%- if section.settings.enable_search -%}
      {% render 'header-search', placeholder: section.settings.search_placeholder, blocks: section.blocks %}
    {%- endif -%}
    <p id="cart" class="header-cart">
      <a href="/cart" data-spark-link="cart">
        <span class="icon cart"></span>
        <strong id="header-cart-item-count">{{ cart.item_count }}</strong>
        <span id="header-cart-total">{{ cart.total_price | money }}</span>
      </a>
    </p>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "main_linklist",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "enable_search",
      "label": "Enable search",
      "default": true
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search products…"
    }
  ],
  "blocks": [
    {
      "type": "search_suggestion",
      "name": "Search suggestion",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "Optional. Uses product, collection, or page title when left blank."
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "info": "Optional. Shown below the title."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Page"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Custom link",
          "info": "Used when no product, collection, or page is selected. Requires a title."
        }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}
