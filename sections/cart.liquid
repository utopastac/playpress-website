<script src="{{ 'cart-ajax.js' | asset_url }}" defer></script>
{{ 'cart.css' | asset_url | stylesheet_tag }}
{{ 'cart-item.css' | asset_url | stylesheet_tag }}

<div is="cart" data-cart-url="{{ routes.cart_url | append: '.js' }}" data-cart-update-url="{{ routes.cart_url | append: '/update.js' }}" data-cart-change-url="{{ routes.cart_url | append: '/change.js' }}" data-discount-root="{{ routes.root_url }}discount/" data-checkout-url="{{ routes.root_url }}checkout">
  <div>
    <form action="/cart" method="post">
      <div>
        <header>
          <h1 id="main-title">Your cart {%- if cart.item_count == 0 %} is empty{%- endif -%}</h1>
          <a is="outline-button" href="/shop">Continue shopping</a>
        </header>
        {%- if cart.item_count > 0 -%}
          <section id="cart-table">
            <ul>
              {%- for item in cart.items -%}
                <li class="cart-item" data-key="{{ item.key }}">
                  <div class="image">
                    <a href="{{ item.url | within: collections.all }}">
                      {%- assign cart_image = item.image | default: item.product.featured_image -%}
                      <img
                        src="{{ cart_image | image_url: width: 200 }}"
                        alt="{{ cart_image.alt | escape }}"
                        width="{{ cart_image.width }}"
                        height="{{ cart_image.height }}"
                        loading="lazy"
                      />
                    </a>
                  </div>
                  <div class="info">
                    <div class="title">
                      <a href="{{ item.url | within: collections.all }}">{{ item.product.title }}</a>
                    </div>
                    <div class="meta">
                      <div class="quantity">
                        <button class="minus item-button "><div class = "icon minus"></div></button>
                        <input
                          name="updates[]"
                          size="2"
                          id="updates_{{ item.id }}"
                          value="{{ item.quantity }}" />
                        <button class="plus item-button"><div class = "icon plus"></div></button>
                      </div>
                      <div class="price">{{ item.final_line_price | money }}</div>
                      <div class="actions">
                        <button class="remove-item item-button"><div class = "icon trash"></div></button>
                      </div>
                    </div>
                  </div>
                </li>
              {%- endfor -%}
            </ul>
            {% comment %} <footer>
              <div scope="row">Total</div>
              <div class="total-price">{{cart.total_price | money }}</div>
              {% comment %} <div><button is="command" type="submit">Update</button></div> {% endcomment %}
            </footer> {% endcomment %}
          </section>
          <div is="checkout">
            <div is="checkout-wrapper">
              <div class="cart-discount">
                <div id="discount-form" class="cart-discount__form">
                  <div class="cart-discount__row">
                    <input
                      type="text"
                      id="discount-code"
                      name="discount"
                      autocomplete="off"
                      placeholder="Discount code"
                    />
                    <button type="button" id="discount-apply" is="outline-button">Apply</button>
                  </div>
                  <div class="cart-discount__chips" id="discount-chips" hidden>
                    <span class="cart-discount__chip">
                      <span class="cart-discount__chip-label" id="discount-chip-label"></span>
                      <button type="button" class="cart-discount__chip-remove" id="discount-chip-remove" aria-label="Remove discount">×</button>
                    </span>
                  </div>
                  <p class="cart-discount__message" id="discount-message" role="status" aria-live="polite" hidden></p>
                </div>
              </div>
              <table class="cart-totals">
                <tbody>
                  <tr class="cart-totals__row cart-totals__subtotal" id="cart-subtotal-row" hidden>
                    <th scope="row">Subtotal</th>
                    <td class="subtotal-price"></td>
                  </tr>
                  <tr class="cart-totals__row cart-totals__discount" id="cart-discount-row" hidden>
                    <th scope="row">Discount</th>
                    <td class="discount-price"></td>
                  </tr>
                  <tr class="cart-totals__row cart-totals__total">
                    <th scope="row">Total</th>
                    <td class="total-price">{{ cart.total_price | money }}</td>
                  </tr>
                </tbody>
              </table>
              <button type="button" id="checkout-button">Proceed to checkout<div class = "icon arrow-right"></div></button>
              <p class="meta">Delivery charges calculated at checkout.</p>
            </div>
            {% render 'delivery' %}
          </div>
        {%- endif -%}
      </div>
    </form>
  </div>
</div>