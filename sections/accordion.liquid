<script src="{{ 'accordion.js' | asset_url }}" defer></script>
{{ 'accordion.css' | asset_url | stylesheet_tag }}

<section is="section">

  {% render 'section-header', title: section.settings.title, text: section.settings.text, center: false %}

  <div is="accordion">
    <div id="accordion-content">

        {% for block in section.blocks %}
          <article is="accordion-item" class="accordion-item">
            <header>
                <h4>{{ block.settings.title | escape }}</h4>
                <div class="icons">
                  <div class="icon plus"></div>
                  <div class="icon minus"></div>
                </div>
            </header>
            <div>{{ block.settings.text }}</div>
          </article>
        {% endfor %}

    </div>
      <div id="accordion-images">
        {% for block in section.blocks %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt }}"
            is="in-action"
            loading="lazy"
            width="800"
            height="600"
            class="accordion-image"
            />
        {% endfor %}
      </div>
  </div>
</section>

{% schema %}
{
  "name": "Accordian",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Add a heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    }
  ],
  "blocks": [
    {
      "type": "accordion_item",
      "name": "accordion item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Add a title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "<p>Add descriptve text</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Accordian",
      "blocks": [
        {
          "type": "accordion_item"
        },
        {
          "type": "accordion_item"
        },
        {
          "type": "accordion_item"
        }
      ]
    }
  ]
}
{% endschema %}
