<script src="{{ 'party-bag-builder.js' | asset_url }}" defer></script>
{{ 'party-bag-builder.css' | asset_url | stylesheet_tag }}

{%- liquid
  capture discount_tiers
    echo '['
    assign first_tier = true
    for i in (1..4)
      assign min_key = 'tier_' | append: i | append: '_min_qty'
      assign disc_key = 'tier_' | append: i | append: '_discount'
      assign min_qty = block.settings[min_key]
      if min_qty > 0
        unless first_tier
          echo ','
        endunless
        echo '{"minQty":' | append: min_qty | append: ',"discount":' | append: block.settings[disc_key] | append: '}'
        assign first_tier = false
      endif
    endfor
    echo ']'
  endcapture
-%}

<section
  is="party-bag-builder"
  style="
    --party-bag-bg: {{ block.settings.background_color }};
    --party-bag-text: {{ block.settings.text_color }};
    --party-bag-price: {{ block.settings.price_color }};
    --party-bag-discount: {{ block.settings.discount_color }};
    --party-bag-card-bg: {{ block.settings.product_card_bg }};
    --party-bag-card-border: {{ block.settings.product_card_border }};
    --party-bag-banner-bg: {{ block.settings.discount_banner_bg }};
    --party-bag-banner-text: {{ block.settings.discount_banner_text }};
    --party-bag-summary-bg: {{ block.settings.summary_bg }};
    --party-bag-summary-border: {{ block.settings.summary_border }};
    --party-bag-btn-bg: {{ block.settings.button_bg_color }};
    --party-bag-btn-text: {{ block.settings.button_text_color }};
    --party-bag-btn-border: {{ block.settings.button_border_color }};
    --party-bag-btn-hover-bg: {{ block.settings.button_hover_bg }};
    --party-bag-btn-hover-text: {{ block.settings.button_hover_text }};
    --party-bag-cta-bg: {{ block.settings.cta_bg_color }};
    --party-bag-cta-text: {{ block.settings.cta_text_color }};
    --party-bag-cta-hover-bg: {{ block.settings.cta_hover_bg }};
    --party-bag-cta-hover-text: {{ block.settings.cta_hover_text }};
    --party-bag-radius: {{ block.settings.border_radius }}px;
    --party-bag-btn-radius: {{ block.settings.button_border_radius }}px;
    --party-bag-title-size: {{ block.settings.title_size }}px;
    --party-bag-description-size: {{ block.settings.description_size }}px;
  "
  data-cart-url="{{ routes.cart_add_url }}"
  data-button-text="{{ block.settings.button_text | escape }}"
  data-discount-tiers='{{ discount_tiers }}'
  {{ block.shopify_attributes }}
>
  <div class="party-bag-builder__container">
    <div class="party-bag-builder__header">
      {%- if block.settings.title != blank -%}
        <h2 class="party-bag-builder__title">{{ block.settings.title }}</h2>
      {%- endif -%}
      {%- if block.settings.description != blank -%}
        <p class="party-bag-builder__description">{{ block.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- assign has_products = false -%}
    {%- for i in (1..12) -%}
      {%- assign product_key = 'product_' | append: i -%}
      {%- assign product = block.settings[product_key] -%}
      {%- if product != blank -%}
        {%- assign has_products = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_products -%}
      <div class="party-bag-builder__discount-banner" data-discount-banner>
        <div class="party-bag-builder__discount-current" data-current-tier>
          Select items to see your discount
        </div>
        <div class="party-bag-builder__discount-next" data-next-tier></div>
      </div>

      <div class="party-bag-builder__products">
        {%- for i in (1..12) -%}
          {%- assign product_key = 'product_' | append: i -%}
          {%- assign product = block.settings[product_key] -%}

          {%- if product != blank -%}
            <div class="party-bag-builder__product" data-product-card>
              <div class="party-bag-builder__product-image-wrapper">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="party-bag-builder__product-image"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {%- else -%}
                  <div class="party-bag-builder__product-image-placeholder">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {%- endif -%}
              </div>

              <div class="party-bag-builder__product-info">
                <h3 class="party-bag-builder__product-title">{{ product.title }}</h3>
                <p class="party-bag-builder__product-price">{{ product.price | money }}</p>
              </div>

              <div class="party-bag-builder__quantity-selector">
                <button
                  type="button"
                  class="party-bag-builder__quantity-button"
                  data-quantity-decrease
                  data-product-id="{{ product.selected_or_first_available_variant.id }}"
                  data-product-price="{{ product.price }}"
                  aria-label="Decrease quantity"
                  disabled
                >
                  −
                </button>
                <span class="party-bag-builder__quantity-display" data-quantity-display>0</span>
                <button
                  type="button"
                  class="party-bag-builder__quantity-button"
                  data-quantity-increase
                  data-product-id="{{ product.selected_or_first_available_variant.id }}"
                  data-product-price="{{ product.price }}"
                  aria-label="Increase quantity"
                >
                  +
                </button>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="party-bag-builder__summary">
        <div class="party-bag-builder__summary-row">
          <span class="party-bag-builder__summary-label">Total items:</span>
          <span class="party-bag-builder__summary-value" data-total-quantity>0</span>
        </div>
        <div class="party-bag-builder__summary-row">
          <span class="party-bag-builder__summary-label">Subtotal:</span>
          <span class="party-bag-builder__summary-value" data-subtotal>{{ 0 | money }}</span>
        </div>
        <div class="party-bag-builder__summary-row" data-discount-row hidden>
          <span class="party-bag-builder__summary-label party-bag-builder__summary-discount">Discount:</span>
          <span class="party-bag-builder__summary-value party-bag-builder__summary-discount" data-discount-amount>{{ 0 | money }}</span>
        </div>
        <div class="party-bag-builder__summary-row party-bag-builder__summary-total">
          <span class="party-bag-builder__summary-label">Total:</span>
          <span class="party-bag-builder__summary-value" data-total>{{ 0 | money }}</span>
        </div>
      </div>

      <button
        type="button"
        class="party-bag-builder__add-to-cart"
        data-add-to-cart
        disabled
      >
        {{ block.settings.button_text }}
      </button>

      <div class="party-bag-builder__message" data-message hidden></div>
    {%- else -%}
      <div class="party-bag-builder__empty-state">
        <p>Add products to your party bag builder in the theme editor settings.</p>
      </div>
    {%- endif -%}
  </div>
</section>

