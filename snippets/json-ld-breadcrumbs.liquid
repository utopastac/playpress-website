{%- if template == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": {{ shop.url | json }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Shop",
      "item": {{ shop.url | append: '/pages/shop/' | json }}
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }}
    }
  ]
}
</script>
{%- endif -%}
